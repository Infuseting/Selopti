{
  "manifest_version": 3,
  "name": "Selopti",
  "version": "0.1.0",
  "description": "Logs new .classified-card elements on SeLoger pages.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://www.seloger.com/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/injector.js"],
      "matches": ["*://www.seloger.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.seloger.com/*"
      ],
      "js": [
        "/dist/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "selopti@infuseting.dev",
      "strict_min_version": "109.0"
    }
  }
}